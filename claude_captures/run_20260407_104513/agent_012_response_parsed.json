id; grid-template-columns: 160px 1fr 100px 100px 80px; align-items: center; padding: 8px 12px; background: rgba(255,255,255,0.02); border-radius: 4px; }\\n  .crate-row:hover { background: rgba(255,255,255,0.05); }\\n  .crate-row .name { font-weight: 600; font-size: 14px; }\\n  .crate-row .bar-container { height: 20px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden; position: relative; }\\n  .crate-row .bar { height: 100%; border-radius: 3px; transition: width 0.3s; }\\n  .crate-row .count { font-size: 13px; text-align: right; color: var(--text-muted); }\\n  .crate-row .status { text-align: center; font-size: 13px; }\\n  .header-row { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); font-weight: 600; }\\n  .header-row .name, .header-row .count, .header-row .status { color: var(--text-muted); }\\n  .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; }\\n  .badge-pass { background: rgba(63,185,80,0.15); color: var(--green); }\\n  .badge-fail { background: rgba(248,81,73,0.15); color: var(--red); }\\n  .badge-none { background: rgba(139,148,158,0.15); color: var(--text-muted); }\\n  .badge-warn { background: rgba(210,153,34,0.15); color: var(--yellow); }\\n\\n  /* Module detail */\\n  .module-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 6px; margin-top: 12px; }\\n  .module-chip { padding: 6px 10px; border-radius: 4px; font-size: 12px; font-family: 'SF Mono', 'Fira Code', monospace; display: flex; justify-content: space-between; align-items: center; }\\n  .module-chip.has-tests { background: rgba(63,185,80,0.08); border: 1px solid rgba(63,185,80,0.2); }\\n  .module-chip.no-tests { background: rgba(248,81,73,0.08); border: 1px solid rgba(248,81,73,0.2); }\\n  .module-chip .mod-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\\n  .module-chip .test-count { font-weight: 600; margin-lef